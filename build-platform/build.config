# Build Platform Configuration
# Customize build behavior by modifying these settings

# ==============================================================================
#  BUILD SETTINGS
# ==============================================================================

# Build output directory BP_OUTPUT_DIR="./dist"

# Cache directory BP_CACHE_DIR="./.build-cache"

# Log directory BP_LOG_DIR="./.build-logs"

# ==============================================================================
#  COMPILER SETTINGS
# ==============================================================================

# Strip comments in production build (0 or 1) BP_STRIP_COMMENTS=1

# Minify output (0 or 1) BP_MINIFY=1

# Preserve debug symbols in dev build (0 or 1) BP_DEBUG_SYMBOLS=1

# ==============================================================================
#  TEST SETTINGS
# ==============================================================================

# Run tests automatically before build (0 or 1) BP_AUTO_TEST=1

# Skip tests (0 or 1) BP_SKIP_TESTS=0

# Test timeout in seconds BP_TEST_TIMEOUT=300

# Fail build on test failures (0 or 1) BP_FAIL_ON_TEST_ERROR=1

# ==============================================================================
#  DOCKER SETTINGS
# ==============================================================================

# Docker image name BP_DOCKER_IMAGE="shell-menu-runner"

# Docker registry (leave empty for local only) BP_DOCKER_REGISTRY=""

# Docker build platforms (comma-separated) BP_DOCKER_PLATFORMS="linux/amd64,linux/arm64"

# Use multi-stage build (0 or 1) BP_DOCKER_MULTISTAGE=1

# ==============================================================================
#  PACKAGE SETTINGS
# ==============================================================================

# Package maintainer BP_PKG_MAINTAINER="Mario Peters<mail@example.com>"

# Package section (for .deb) BP_PKG_SECTION="utils"

# Package priority BP_PKG_PRIORITY="optional"

# Package architecture BP_PKG_ARCH="all"

# ==============================================================================
#  DEPLOYMENT SETTINGS
# ==============================================================================

# GitHub repository (owner/repo) BP_GITHUB_REPO="MarioPeters/shell-menu-runner"

# Docker Hub username BP_DOCKERHUB_USER="mariopeters"

# Automatically create GitHub release (0 or 1) BP_AUTO_RELEASE=0

# Automatically push to Docker Hub (0 or 1) BP_AUTO_DOCKER_PUSH=0

# ==============================================================================
#  OPTIMIZATION SETTINGS
# ==============================================================================

# Enable parallel builds (0 or 1) BP_PARALLEL=1

# Number of parallel jobs (0 = auto) BP_PARALLEL_JOBS=0

# Use ccache for compilation caching (0 or 1) BP_USE_CACHE=1

# Cache TTL in seconds BP_CACHE_TTL=3600

# ==============================================================================
#  QUALITY SETTINGS
# ==============================================================================

# Run shellcheck (0 or 1) BP_RUN_SHELLCHECK=1

# ShellCheck severity (error, warning, info, style) BP_SHELLCHECK_SEVERITY="warning"

# Run security scan (0 or 1) BP_RUN_SECURITY_SCAN=0

# Generate code coverage (0 or 1) BP_CODE_COVERAGE=0

# ==============================================================================
#  LOGGING SETTINGS
# ==============================================================================

# Enable verbose logging (0 or 1) BP_VERBOSE=0

# Enable debug mode (0 or 1) BP_DEBUG=0

# Log format (text, json) BP_LOG_FORMAT="text"

# Enable colored output (0 or 1) BP_NO_COLOR=0

# ==============================================================================
#  NOTIFICATION SETTINGS
# ==============================================================================

# Send build notifications (0 or 1) BP_NOTIFY=0

# Notification webhook URL BP_NOTIFY_WEBHOOK=""

# Notify on success (0 or 1) BP_NOTIFY_SUCCESS=1

# Notify on failure (0 or 1) BP_NOTIFY_FAILURE=1
